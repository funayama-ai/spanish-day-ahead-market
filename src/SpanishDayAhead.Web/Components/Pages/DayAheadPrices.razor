@page "/"
@page "/day-ahead-prices"
@rendermode InteractiveServer

@using System.Globalization
@using SpanishDayAhead.Web.Models
@using SpanishDayAhead.Web.Services

@inject DayAheadPriceApiClient ApiClient

<PageTitle>Spanish Day-Ahead Market</PageTitle>

<h1>Spanish Day-Ahead Market</h1>

<p class="text-muted">
    Real Spanish Day-Ahead auction prices retrieved from the REST API.
</p>

<div class="control-panel">
    <div class="date-control">
        <label for="delivery-date">
            Delivery date
        </label>

        <input id="delivery-date" type="date" class="form-control" value="@_selectedDateText"
               @onchange="OnDeliveryDateChanged" />
    </div>

    <button class="btn btn-primary load-button" @onclick="LoadPricesAsync" disabled="@_isLoading">
        @if (_isLoading)
        {
            <span>Loading...</span>
        }
        else
        {
            <span>Load Data</span>
        }
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger mt-3">
        @_errorMessage
    </div>
}
else if (_isLoading)
{
    <div class="alert alert-info mt-3">
        Loading Day-Ahead prices from the REST API...
    </div>
}
else if (_hasLoaded && _prices.Count == 0)
{
    <div class="alert alert-warning mt-3">
        No stored Day-Ahead prices were found for
        @(_selectedDate.ToString(
            "yyyy-MM-dd",
            CultureInfo.InvariantCulture)).
    </div>
}
else if (_prices.Count > 0)
{
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label">
                Records
            </div>

            <div class="kpi-value">
                @_prices.Count
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-label">
                Average price
            </div>

            <div class="kpi-value">
                @AveragePrice.ToString(
                    "0.00",
                    CultureInfo.InvariantCulture)

                <span class="kpi-unit">
                    EUR/MWh
                </span>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-label">
                Minimum price
            </div>

            <div class="kpi-value">
                @MinimumPrice.ToString(
                    "0.00",
                    CultureInfo.InvariantCulture)

                <span class="kpi-unit">
                    EUR/MWh
                </span>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-label">
                Maximum price
            </div>

            <div class="kpi-value">
                @MaximumPrice.ToString(
                    "0.00",
                    CultureInfo.InvariantCulture)

                <span class="kpi-unit">
                    EUR/MWh
                </span>
            </div>
        </div>
    </div>

    <section class="dashboard-section">
        <h2>Day-Ahead price profile</h2>

        <div class="chart-wrapper">
            <svg viewBox="0 0 1000 340" role="img" aria-label="Spanish Day-Ahead price chart">

                <line x1="70" y1="20" x2="70" y2="290" class="chart-axis" />

                <line x1="70" y1="290" x2="970" y2="290" class="chart-axis" />

                @foreach (var tick in YAxisTicks)
                {
                    <g>
                        <line x1="70" y1="@tick.Y" x2="970" y2="@tick.Y" class="chart-grid-line" />

                        <text x="60" y="@(tick.Y + 5)" text-anchor="end" class="chart-label">
                            @tick.Value.ToString(
                                "0",
                                CultureInfo.InvariantCulture)
                        </text>
                    </g>
                }

                @foreach (var tick in XAxisTicks)
                {
                    <g>
                        <line x1="@tick.X" y1="290" x2="@tick.X" y2="296" class="chart-axis" />

                        <text x="@tick.X" y="316" text-anchor="middle" class="chart-label">
                            @tick.Label
                        </text>
                    </g>
                }

                <polyline points="@ChartPoints" class="price-line" />

                @foreach (var point in ChartDataPoints)
                {
                    <circle cx="@point.X" cy="@point.Y" r="2.5" class="price-point">
                        <title>
                            @point.TimeLabel:
                            @point.Price.ToString(
                                "0.00",
                                CultureInfo.InvariantCulture)
                            EUR/MWh
                        </title>
                    </circle>
                }

                <text x="20" y="18" class="chart-title-label">
                    EUR/MWh
                </text>

                <text x="520" y="337" text-anchor="middle" class="chart-title-label">
                    Spanish local time
                </text>
            </svg>
        </div>
    </section>

    <section class="dashboard-section">
        <h2>Price table</h2>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Period</th>
                        <th>Local start</th>
                        <th>UTC start</th>
                        <th>Price</th>
                        <th>Resolution</th>
                        <th>Source version</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var price in _prices)
                    {
                        <tr>
                            <td>
                                @price.Period
                            </td>

                            <td>
                                @(price.DeliveryStartLocal.ToString(
                                    "yyyy-MM-dd HH:mm zzz",
                                    CultureInfo.InvariantCulture))
                            </td>

                            <td>
                                @(price.DeliveryStartUtc
                                    .ToUniversalTime()
                                    .ToString(
                                        "yyyy-MM-dd HH:mm 'UTC'",
                                        CultureInfo.InvariantCulture))
                            </td>

                            <td>
                                <strong>
                                    @(price.PriceEurPerMWh.ToString(
                                        "0.00",
                                        CultureInfo.InvariantCulture))
                                </strong>
                                EUR/MWh
                            </td>

                            <td>
                                @price.ResolutionMinutes min
                            </td>

                            <td>
                                @price.SourceVersion
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="source-information">
            <strong>Source file:</strong>
            @_prices[0].SourceFileName
        </div>
    </section>
}

@code {
    private readonly List<DayAheadPriceDto> _prices = [];

    private DateOnly _selectedDate =
        new(2026, 7, 11);

    private string _selectedDateText =
        "2026-07-11";

    private bool _isLoading;
    private bool _hasLoaded;
    private string? _errorMessage;

    private decimal AveragePrice =>
        _prices.Count == 0
            ? 0m
            : _prices.Average(
                price => price.PriceEurPerMWh);

    private decimal MinimumPrice =>
        _prices.Count == 0
            ? 0m
            : _prices.Min(
                price => price.PriceEurPerMWh);

    private decimal MaximumPrice =>
        _prices.Count == 0
            ? 0m
            : _prices.Max(
                price => price.PriceEurPerMWh);

    private IReadOnlyList<ChartPoint> ChartDataPoints =>
        BuildChartDataPoints();

    private string ChartPoints =>
        string.Join(
            " ",
            ChartDataPoints.Select(
                point =>
                    $"{point.X.ToString(
                        "0.##",
                        CultureInfo.InvariantCulture)}," +
                    $"{point.Y.ToString(
                        "0.##",
                        CultureInfo.InvariantCulture)}"));

    private IReadOnlyList<YAxisTick> YAxisTicks =>
        BuildYAxisTicks();

    private IReadOnlyList<XAxisTick> XAxisTicks =>
        BuildXAxisTicks();

    protected override async Task OnInitializedAsync()
    {
        await LoadPricesAsync();
    }

    private void OnDeliveryDateChanged(
        ChangeEventArgs eventArgs)
    {
        var value =
            eventArgs.Value?.ToString();

        if (DateOnly.TryParseExact(
                value,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var parsedDate))
        {
            _selectedDate = parsedDate;
            _selectedDateText = value!;
        }
    }

    private async Task LoadPricesAsync()
    {
        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        _hasLoaded = false;
        _errorMessage = null;

        try
        {
            var results =
                await ApiClient.GetByDeliveryDateAsync(
                    _selectedDate);

            _prices.Clear();
            _prices.AddRange(results);

            _hasLoaded = true;
        }
        catch (HttpRequestException exception)
        {
            _errorMessage =
                "The REST API could not be reached. " +
                "Confirm that SpanishDayAhead.Api is running.";

            Console.Error.WriteLine(exception);
        }
        catch (Exception exception)
        {
            _errorMessage =
                "An unexpected error occurred while loading " +
                "the Day-Ahead prices.";

            Console.Error.WriteLine(exception);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IReadOnlyList<ChartPoint>
        BuildChartDataPoints()
    {
        if (_prices.Count == 0)
        {
            return Array.Empty<ChartPoint>();
        }

        const double left = 70;
        const double top = 20;
        const double width = 900;
        const double height = 270;

        var minimum =
            (double)MinimumPrice;

        var maximum =
            (double)MaximumPrice;

        var range =
            maximum - minimum;

        if (Math.Abs(range) < 0.000001)
        {
            range = 1;
        }

        var points =
            new List<ChartPoint>(
                _prices.Count);

        for (var index = 0;
             index < _prices.Count;
             index++)
        {
            var price =
                _prices[index];

            var x =
                _prices.Count == 1
                    ? left
                    : left +
                      index * width /
                      (_prices.Count - 1);

            var normalizedPrice =
                ((double)price.PriceEurPerMWh -
                 minimum) /
                range;

            var y =
                top +
                height -
                normalizedPrice * height;

            points.Add(
                new ChartPoint(
                    X: x,
                    Y: y,
                    Price: price.PriceEurPerMWh,
                    TimeLabel:
                        price.DeliveryStartLocal.ToString(
                            "HH:mm",
                            CultureInfo.InvariantCulture)));
        }

        return points;
    }

    private IReadOnlyList<YAxisTick>
        BuildYAxisTicks()
    {
        if (_prices.Count == 0)
        {
            return Array.Empty<YAxisTick>();
        }

        const double top = 20;
        const double height = 270;
        const int tickCount = 5;

        var minimum =
            (double)MinimumPrice;

        var maximum =
            (double)MaximumPrice;

        var range =
            maximum - minimum;

        if (Math.Abs(range) < 0.000001)
        {
            range = 1;
        }

        var ticks =
            new List<YAxisTick>(
                tickCount + 1);

        for (var index = 0;
             index <= tickCount;
             index++)
        {
            var ratio =
                index /
                (double)tickCount;

            var value =
                maximum -
                ratio * range;

            var y =
                top +
                ratio * height;

            ticks.Add(
                new YAxisTick(
                    Value: value,
                    Y: y));
        }

        return ticks;
    }

    private IReadOnlyList<XAxisTick>
        BuildXAxisTicks()
    {
        if (_prices.Count == 0)
        {
            return Array.Empty<XAxisTick>();
        }

        const double left = 70;
        const double width = 900;

        var selectedIndexes =
            new[]
            {
                0,
                _prices.Count / 4,
                _prices.Count / 2,
                _prices.Count * 3 / 4,
                _prices.Count - 1
            }
            .Distinct()
            .ToList();

        var ticks =
            new List<XAxisTick>(
                selectedIndexes.Count);

        foreach (var index in selectedIndexes)
        {
            var x =
                _prices.Count == 1
                    ? left
                    : left +
                      index * width /
                      (_prices.Count - 1);

            ticks.Add(
                new XAxisTick(
                    X: x,
                    Label:
                        _prices[index]
                            .DeliveryStartLocal
                            .ToString(
                                "HH:mm",
                                CultureInfo.InvariantCulture)));
        }

        return ticks;
    }

    private sealed record ChartPoint(
        double X,
        double Y,
        decimal Price,
        string TimeLabel);

    private sealed record YAxisTick(
        double Value,
        double Y);

    private sealed record XAxisTick(
        double X,
        string Label);
}

<style>
    .control-panel {
        display: flex;
        align-items: end;
        gap: 1rem;
        margin: 1.5rem 0;
        padding: 1rem;
        border: 1px solid #d9dee7;
        border-radius: 0.5rem;
        background: #f8f9fb;
    }

    .date-control {
        width: 230px;
    }

    .date-control label {
        display: block;
        margin-bottom: 0.4rem;
        font-weight: 600;
    }

    .load-button {
        min-width: 120px;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns:
            repeat(auto-fit,
                minmax(180px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0;
    }

    .kpi-card {
        padding: 1.1rem;
        border: 1px solid #d9dee7;
        border-radius: 0.5rem;
        background: white;
        box-shadow:
            0 2px 5px rgba(0, 0, 0, 0.05);
    }

    .kpi-label {
        color: #5f6875;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .kpi-value {
        margin-top: 0.4rem;
        font-size: 1.55rem;
        font-weight: 700;
    }

    .kpi-unit {
        font-size: 0.8rem;
        font-weight: 500;
    }

    .dashboard-section {
        margin-top: 2rem;
    }

    .chart-wrapper {
        overflow-x: auto;
        padding: 1rem;
        border: 1px solid #d9dee7;
        border-radius: 0.5rem;
        background: white;
    }

    .chart-wrapper svg {
        width: 100%;
        min-width: 760px;
        height: auto;
    }

    .chart-axis {
        stroke: #303844;
        stroke-width: 1.5;
    }

    .chart-grid-line {
        stroke: #d9dee7;
        stroke-width: 1;
        stroke-dasharray: 4 4;
    }

    .chart-label {
        fill: #596273;
        font-size: 12px;
    }

    .chart-title-label {
        fill: #303844;
        font-size: 13px;
        font-weight: 600;
    }

    .price-line {
        fill: none;
        stroke: #165dff;
        stroke-width: 3;
        stroke-linejoin: round;
        stroke-linecap: round;
    }

    .price-point {
        fill: #165dff;
    }

    .source-information {
        margin-top: 1rem;
        color: #5f6875;
        font-size: 0.9rem;
    }

    @@media (max-width: 700px) {
        .control-panel {
            align-items: stretch;
            flex-direction: column;
        }

        .date-control {
            width: 100%;
        }

        .load-button {
            width: 100%;
        }
    }
</style>